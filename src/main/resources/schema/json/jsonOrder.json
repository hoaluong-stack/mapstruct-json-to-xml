{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "JsonOrder",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "orderId",
    "orderDate",
    "sourceSystem",
    "salesChannel",
    "currency",
    "paymentMethod",
    "couponCode",
    "discountAmount",
    "shippingFee",
    "taxAmount",
    "priority",
    "orderStatus",
    "customer",
    "items",
    "totalAmount"
  ],
  "properties": {
    "orderId": { "type": "string" },
    "orderDate": { "type": "string", "format": "date" },
    "sourceSystem": { "type": "string" },
    "salesChannel": { "type": "string" },
    "currency": { "type": "string" },
    "paymentMethod": { "type": "string" },
    "couponCode": { "type": "string" },
    "discountAmount": { "type": "number" },
    "shippingFee": { "type": "number" },
    "taxAmount": { "type": "number" },
    "priority": { "type": "string" },
    "orderStatus": { "type": "string" },
    "customer": { "$ref": "#/$defs/JsonCustomer" },
    "items": {
      "type": "array",
      "items": { "$ref": "#/$defs/JsonItem" }
    },
    "totalAmount": { "type": "number" }
  },
  "$defs": {
    "JsonCustomer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "customerId",
        "firstName",
        "lastName",
        "email",
        "phone",
        "address",
        "loyaltyLevel",
        "birthDate",
        "gender",
        "companyName",
        "taxNumber",
        "countryCode",
        "city",
        "postalCode",
        "marketingOptIn",
        "loyaltyPoints",
        "vipSince"
      ],
      "properties": {
        "customerId": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "loyaltyLevel": { "type": "string" },
        "birthDate": { "type": "string", "format": "date" },
        "gender": { "type": "string" },
        "companyName": { "type": "string" },
        "taxNumber": { "type": "string" },
        "countryCode": { "type": "string" },
        "city": { "type": "string" },
        "postalCode": { "type": "string" },
        "marketingOptIn": { "type": "boolean" },
        "loyaltyPoints": { "type": "integer" },
        "vipSince": { "type": "string", "format": "date" }
      }
    },
    "JsonItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sku",
        "itemName",
        "quantity",
        "unitPrice",
        "category",
        "brand",
        "weightKg",
        "giftWrap",
        "warehouseCode",
        "note",
        "color",
        "size",
        "material",
        "originCountry",
        "barcode",
        "serialNumber",
        "warrantyMonths",
        "fragile",
        "expiryDate",
        "supplierCode"
      ],
      "properties": {
        "sku": { "type": "string" },
        "itemName": { "type": "string" },
        "quantity": { "type": "integer" },
        "unitPrice": { "type": "number" },
        "category": { "type": "string" },
        "brand": { "type": "string" },
        "weightKg": { "type": "number" },
        "giftWrap": { "type": "boolean" },
        "warehouseCode": { "type": "string" },
        "note": { "type": "string" },
        "color": { "type": "string" },
        "size": { "type": "string" },
        "material": { "type": "string" },
        "originCountry": { "type": "string" },
        "barcode": { "type": "string" },
        "serialNumber": { "type": "string" },
        "warrantyMonths": { "type": "integer" },
        "fragile": { "type": "boolean" },
        "expiryDate": { "type": "string", "format": "date" },
        "supplierCode": { "type": "string" }
      }
    }
  }
}
